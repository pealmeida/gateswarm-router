        "modelFlag": "--model",
        "inputFormat": "arg",
        "outputFormat": "stdout-text",
        "timeoutMs": 300000,
        "maxTokens": 64000,
        "maxConcurrent": 1,
        "modelAlias": {
          "cc/claude-sonnet-4-6": "claude-sonnet-4-6",
